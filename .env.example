# BODYBALANCE.AI Environment Variables
# Copy this file to .env and fill in your values

# Google Sheets Integration (optional)
BODYBALANCE_GOOGLE_SHEET_ID=your_google_sheet_id_here
GOOGLE_APPLICATION_CREDENTIALS=path/to/your/credentials.json

# NLP Settings
BODYBALANCE_SIMILARITY_THRESHOLD=0.3

# Cache Settings
BODYBALANCE_CACHE_TTL=5

# Session Settings
BODYBALANCE_SESSION_TIMEOUT=30
BODYBALANCE_FEEDBACK_ENABLED=true

# Admin Settings (CHANGE IN PRODUCTION!)
BODYBALANCE_ADMIN_PASSWORD=admin123

# Logging
BODYBALANCE_LOG_LEVEL=INFO

# Support Contact
BODYBALANCE_SUPPORT_EMAIL=support@bodybalance.com
BODYBALANCE_SUPPORT_PHONE=+234 XXX XXX XXXX
